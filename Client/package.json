{
  "name": "client",
  "main": "expo-router/entry",
  "version": "1.0.2",
  "scripts": {
    "start": "npx expo start",
    "start:tunnel": "npx expo start --tunnel",
    "start:clear": "npx expo start --clear",
    "start:tunnel:clear": "npx expo start --tunnel --clear",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "web:build": "npx expo export --platform web",
    "web:deploy:aws": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-web-aws.ps1",
    "web:https": "npm run web:build && node https-server.js",
    "web:dev:https": "node https-dev-proxy.js",
    "analyze:loc": "node ./scripts/analyze-loc.cjs",
    "analyze:loc:src": "node ./scripts/analyze-loc.cjs --src-only",
    "analyze:unused-loc": "node ./scripts/analyze-unused-loc.cjs",
    "eas:build:development": "npx eas build --platform android --profile development",
    "eas:build:preview": "npx eas build --platform android --profile preview",
    "eas:build:production": "npx eas build --platform android --profile production",
    "proxy": "node https-dev-proxy.js",
    "lint": "npx expo lint",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "overrides": {
    "glob": "^12.0.0",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@expo/vector-icons": "^15.0.3",
    "@microsoft/signalr": "^8.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@types/signalr": "^2.4.3",
    "axios": "^1.16.1",
    "babel-preset-expo": "~55.0.8",
    "date-fns": "^4.1.0",
    "expo": "^55.0.26",
    "expo-auth-session": "^55.0.6",
    "expo-calendar": "~55.0.15",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.9",
    "expo-file-system": "~55.0.9",
    "expo-font": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.9",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.10",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.2",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.4.1",
    "react-native": "0.83.6",
    "react-native-calendars": "^1.1311.0",
    "react-native-geocoding": "^0.5.0",
    "react-native-maps": "1.27.2",
    "react-native-paper": "^5.13.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-toast-message": "^2.2.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-rating": "^2.0.5",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/google.maps": "^3.58.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.2",
    "@types/react": "~19.2.10",
    "baseline-browser-mapping": "^2.10.29",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "knip": "^6.13.1",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}

{
  "ConnectionStrings": {
    "DefaultConnection": "Server=<RDS_ENDPOINT>,1433;Database=<DB_NAME>;User Id=<DB_USER>;Password=<DB_PASSWORD>;Encrypt=True;TrustServerCertificate=False;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "<JWT_KEY>",
    "Issuer": "<JWT_ISSUER>",
    "Audience": "<JWT_AUDIENCE>"
  },
  "AppSettings": {
    "LocalIP": "<LOCAL_IP>",
    "ApiPort": "8000",
    "ClientPort": "8081"
  },
  "Storage": {
    "Provider": "Local",
    "LocalRootPath": "<ABSOLUTE_PATH_FOR_UPLOADS>",
    "S3BucketName": "<S3_BUCKET_NAME>",
    "S3Region": "<AWS_REGION>",
    "S3KeyPrefix": "uploads",
    "S3PublicBaseUrl": "<OPTIONAL_CLOUDFRONT_OR_S3_PUBLIC_BASE_URL>"
  },
  "Authentication": {
    "Google": {
      "ClientId": "<GOOGLE_CLIENT_ID>",
      "ClientSecret": "<GOOGLE_CLIENT_SECRET>"
    },
    "Facebook": {
      "ClientId": "<FACEBOOK_CLIENT_ID>",
      "ClientSecret": "<FACEBOOK_CLIENT_SECRET>"
    },
    "Microsoft": {
      "ClientId": "<MICROSOFT_CLIENT_ID>",
      "ClientSecret": "<MICROSOFT_CLIENT_SECRET>",
      "TenantId": "<MICROSOFT_TENANT_ID_OR_common>"
    }
  },
  "Client": {
    "Url": "<CLIENT_URL>"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:19006",
      "https://localhost:8081",
      "https://maps.googleapis.com/maps/api"
    ]
  }
}
